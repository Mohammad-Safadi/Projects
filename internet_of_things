void shuffleArray(int arr[], int n) {
    srand(time(NULL)); // Seed the random number generator
    for (int i = n - 1; i > 0; i--) {
        int j = rand() % (i + 1); // Generate a random index from 0 to i
        // Swap arr[i] with the element at random index j
        int temp = arr[i];
        arr[i] = arr[j];
        arr[j] = temp;
    }
}

String getColorName(uint32_t colorValue) {
    uint8_t red = (colorValue >> 16) & 0xFF;    // Extract red component
    uint8_t green = (colorValue >> 8) & 0xFF;   // Extract green component
    uint8_t blue = colorValue & 0xFF;           // Extract blue component

    int tolerance = 15;
    if (red >= 255 - tolerance && green <= tolerance && blue <= tolerance) {
        return "Red";
    } else if (red <= tolerance && green >= 255 - tolerance && blue <= tolerance) {
        return "Green";
    } else if (red <= tolerance && green <= tolerance && blue >= 255 - tolerance) {
        return "Blue";
    } else if (red >= 255 - tolerance && green >= 255 - tolerance && blue >= 255 - tolerance) {
        return "White";
    } else if (red >= 255 - tolerance && green >= 255 - tolerance && blue <= tolerance) {
        return "Yellow";
    } else {
        return "Unknown"; // Color doesn't match predefined colors
    }
}

