            colorname = "White";
            break;
        case 5:
            soundtoplay = YELLOW_SOUND_INDEX;
            colorname = "Yellow" ;
            break;
        default:
            // Handle invalid index
            soundtoplay = DEFAULT_SOUND_INDEX;
            break;
    }
    if(digitalRead(SWITCH_PIN)==LOW){

        playcolorsound(1, soundtoplay);
    }
    stripColors(0);

    // Check NeoPixel color at the chosen index
    //uint32_t colorhex = NeoPixel.getPixelColor(ndx - 1);
    //String colorname = getColorName(colorhex);
    // Find the LED number matching the color
    int8_t matchedLEDNumber = -1;

    uint32_t temp;
    String color_check;
    delay(100);
    for (int i = 0; i < NUM_COLORS; ++i) {
        temp = NeoPixel.getPixelColor(i);
        color_check =  getColorName(temp) ;

        if (  colorname == color_check  )
        {
            matchedLEDNumber = i ; // LED numbers start from 1
            break;
        }
    }


    int get_index;
    for(int i=1 ; i<=5 ;i++){
        if( first_mapping[i] == matchedLEDNumber ){
            get_index = i;
        }
    }



    delay(100);
    if (prevLEDNumber == currentLEDNumber) {
        int flickerDelay = random(90, 100); // Random delay between flickers (adjust as needed)
        delay(flickerDelay);
        if(digitalRead(SWITCH_PIN)==HIGH){
            digitalWrite(led_pins[get_index - 1], HIGH); // Turn on the LED
            delay(100);        // Delay for a short period
            digitalWrite(led_pins[get_index - 1], LOW);  // Turn off the LED
        }
        delay(flickerDelay);        // Delay for a short period
    }
    counter++;
    if(digitalRead(SWITCH_PIN)==HIGH){
        digitalWrite(led_pins[get_index - 1], HIGH);
    }
    ledStartTime = millis();
    ledOn = true;
    return get_index;
}
